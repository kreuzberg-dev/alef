/// Swift protocol that Swift classes implement to provide visitor callbacks.
/// Conform to this protocol to intercept HTMLâ†’Markdown conversion events.
public protocol MarkupVisitorProtocol: AnyObject {
    func visitNode(_ tag: String) -> VisitResult
