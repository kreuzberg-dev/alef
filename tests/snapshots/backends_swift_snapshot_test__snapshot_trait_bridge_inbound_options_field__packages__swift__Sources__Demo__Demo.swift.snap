/// Wrap a `MarkupVisitorProtocol` conformer in an opaque `CallbackHandle` handle
/// that can be passed to `conversionOptionsFromJsonWithVisitor(...)` on the Rust side.
public func makeMarkupCallbackHandle(_ visitor: any MarkupVisitorProtocol) -> CallbackHandle {
    return RustBridge.makeMarkupCallbackHandle(SwiftMarkupVisitorBox(_MarkupVisitorProtocolAdapter(visitor)))
}

