/// Default implementation: every method returns `.`continue`` so conforming
/// types only need to implement the callbacks they care about.
public extension MarkupVisitorProtocol {
    func visitNode(_ _tag: String) -> VisitResult { return .`continue` }
}

/// Internal adapter: wraps a `MarkupVisitorProtocol` conformer as a `_SwiftMarkupVisitorBoxDelegate`.
/// Converts swift-bridge raw types (RustString, UInt, etc.) to user-friendly Swift
/// types before dispatching, and serialises the `VisitResult` return to JSON.
private final class _MarkupVisitorProtocolAdapter: _SwiftMarkupVisitorBoxDelegate {
