{# Per-variant constructor on a flat data enum. Builds the flat struct directly: discriminator tag
   plus the variant's flat field(s); `..Default::default()` covers the rest unless this variant
   already covers every flat field. Exposed to PHP under the snake name; Rust fn is `_factory_<snake>`
   to avoid colliding with the variant's `get_<flat>` accessor. #}
#[php(name = "{{ php_name }}")]
pub fn {{ rust_fn_name }}({{ params }}) -> Self {
    Self { {{ tag_field }}_tag: "{{ tag_val }}".to_string(), {{ field_inits | join(", ") }}{% if needs_default %}, ..Default::default(){% endif %} }
}
