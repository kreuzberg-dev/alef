let func: napi::bindgen_prelude::Function<{{ args_tuple_ty }}, napi::bindgen_prelude::Unknown> = match self.inner.get_named_property("{{ method_name }}") {
    Ok(f) => f,
{% if has_error %}
    Err(e) => return Err({{ error_lookup }}),
{% else %}
    Err(_) => return Default::default(),
{% endif %}
};

{% if empty_args %}
let result = func.call(());
{% else %}
let result = func.call(napi::bindgen_prelude::FnArgs::from({{ tuple_args }}));
{% endif %}

{% if has_error %}
match result {
    Err(e) => Err({{ error_call }}),
    Ok(val) => {
        // Convert JS value to Rust type via string coercion
        let s = val.coerce_to_string()
            .and_then(|s| s.into_utf8())
            .and_then(|s| s.into_owned())
            .map_err(|e| {{ error_coercion }})?;
        match s.as_str() {
            "" | "null" => Ok(Default::default()),
            _ => {
                serde_json::from_str::<_>(&s).map_err(|_| {{ error_parse }})
            }
        }
    }
}
{% else %}
match result {
    Err(_) => Default::default(),
    Ok(val) => {
        // Convert JS value to Rust type via string coercion
        let s = val.coerce_to_string()
            .and_then(|s| s.into_utf8())
            .and_then(|s| s.into_owned())
            .unwrap_or_default();
        match s.as_str() {
            "" | "null" => Default::default(),
            _ => serde_json::from_str::<_>(&s).unwrap_or_default()
        }
    }
}
{% endif %}
